else if mtfAnchorChanged or na(previousAnchorBaseLine) or na(previousAnchorTerminalLine) or na(lblPreviousAnchorBase) or na(lblPreviousAnchorTerminal)
    float previousAnchorBasePrice = mtfPreviousPrimaryDirRaw == 1 ? mtfPreviousPrimaryLowRaw : mtfPreviousPrimaryHighRaw
    float previousAnchorTerminalPrice = mtfPreviousPrimaryDirRaw == 1 ? mtfPreviousPrimaryHighRaw : mtfPreviousPrimaryLowRaw
    color previousAnchorLabelColor = color.new(color.gray, VIS_TRANS_STATE_LABEL)
    if not na(previousAnchorBaseLine)
        line.delete(previousAnchorBaseLine)
        previousAnchorBaseLine := na
    if not na(previousAnchorTerminalLine)
        line.delete(previousAnchorTerminalLine)
