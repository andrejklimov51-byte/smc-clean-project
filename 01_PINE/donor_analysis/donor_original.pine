    finalLblProtectedLevel := label.new(mtfCurrentPrimaryProtectedTime, mtfCurrentPrimaryProtectedLevel, "ЗАЩ. УРОВЕНЬ 1H", xloc=xloc.bar_time, style=mtfCurrentPrimaryDir == 1 ? label.style_label_up : label.style_label_down, color=protectedLevelLabelColor, textcolor=color.white)

if protectedLevelDebugEnabled and protectedLevelShow079Compare and currentPrimaryVisualAllowed and not na(mtfCurrentPrimaryBreakLevel)
    color temp079DebugColor = color.new(color.yellow, 78)
