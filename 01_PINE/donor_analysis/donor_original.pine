    float currentPrimaryTerminalPrice = mtfCurrentPrimaryDir == 1 ? mtfCurrentPrimaryHigh : mtfCurrentPrimaryLow
    float currentPrimaryConfirmPrice = mtfCurrentPrimaryDir == 1 ? mtfCurrentPrimaryHigh - mtfCurrentPrimaryRange * 0.5 : mtfCurrentPrimaryLow + mtfCurrentPrimaryRange * 0.5
    color currentBaseLineColor = currentPrimaryIsBrokenVisual ? color.new(color.blue, 65) : color.blue
    color currentTerminalLineColor = currentPrimaryIsBrokenVisual ? color.new(color.orange, 65) : color.orange
    color currentBaseLabelColor = color.new(color.blue, VIS_TRANS_STATE_LABEL)
    color currentTerminalLabelColor = color.new(color.orange, VIS_TRANS_STATE_LABEL)
    color currentStateColor = currentPrimaryIsBrokenVisual ? color.red : currentPrimaryIsActiveVisual ? color.green : color.gray
    color currentStateLabelColor = color.new(currentStateColor, VIS_TRANS_STATE_LABEL)
    string currentStateLabelText = currentPrimaryIsBrokenVisual ? "СЛОМ " + rolePrimaryProof + " ОСН." : currentPrimaryIsActiveVisual ? rolePrimaryProof + " ОСН. АКТИВ" : rolePrimaryProof + " ОСН. НЕАКТИВЕН"
    currentPrimaryBaseLine := line.new(mtfCurrentPrimaryStartTime, currentPrimaryBasePrice, time, currentPrimaryBasePrice, xloc=xloc.bar_time, extend=extend.right, color=currentBaseLineColor, width=1)
    currentPrimaryTerminalLine := line.new(mtfCurrentPrimaryProvisionalEndTime, currentPrimaryTerminalPrice, time, currentPrimaryTerminalPrice, xloc=xloc.bar_time, extend=extend.right, color=currentTerminalLineColor, width=1)
    lblCurrentPrimaryBase := label.new(mtfCurrentPrimaryStartTime, currentPrimaryBasePrice, rolePrimaryProof + " ОСН. БАЗА", xloc=xloc.bar_time, style=mtfCurrentPrimaryDir == 1 ? label.style_label_up : label.style_label_down, color=currentBaseLabelColor, textcolor=color.white)
    lblCurrentPrimaryTerminal := label.new(mtfCurrentPrimaryProvisionalEndTime, currentPrimaryTerminalPrice, rolePrimaryProof + " ОСН. КОНЕЦ", xloc=xloc.bar_time, style=mtfCurrentPrimaryDir == 1 ? label.style_label_down : label.style_label_up, color=currentTerminalLabelColor, textcolor=color.white)
    lblCurrentPrimaryState := label.new(mtfCurrentPrimaryConfirmedEndTime, currentPrimaryConfirmPrice, currentStateLabelText, xloc=xloc.bar_time, style=label.style_label_left, color=currentStateLabelColor, textcolor=color.white)

if protectedLevelDebugEnabled and mtfCurrentPrimaryProtectedValid and not na(mtfCurrentPrimaryProtectedLevel) and not na(mtfCurrentPrimaryProtectedTime)
