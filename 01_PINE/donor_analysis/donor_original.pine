if activeOwnerStateFinal == "CURRENT"
    activeOwnerStartTime := mtfCurrentPrimaryStartTime
    activeOwnerConfirmedEndTime := mtfCurrentPrimaryConfirmedEndTime
    activeOwnerLow := mtfCurrentPrimaryLow
    activeOwnerHigh := mtfCurrentPrimaryHigh
    activeOwnerDir := mtfCurrentPrimaryDir
    activeOwnerRange := mtfCurrentPrimaryRange
else if activeOwnerStateFinal == "PREVIOUS" or activeOwnerStateFinal == "PREVIOUS_AFTER_ROLLBACK"
    activeOwnerStartTime := mtfPreviousPrimaryStartTimeRaw
    activeOwnerConfirmedEndTime := mtfPreviousPrimaryConfirmedEndTimeRaw
    activeOwnerLow := mtfPreviousPrimaryLowRaw
    activeOwnerHigh := mtfPreviousPrimaryHighRaw
    activeOwnerDir := mtfPreviousPrimaryDirRaw
    activeOwnerRange := mtfPreviousPrimaryRangeRaw

bool fibVisualOwnerActive = activeOwnerExistsFinal and not na(activeOwnerStartTime) and not na(activeOwnerConfirmedEndTime) and not na(activeOwnerLow) and not na(activeOwnerHigh) and activeOwnerDir != 0 and not na(activeOwnerRange) and activeOwnerRange > syminfo.mintick
float currentFibVisualBasePrice = fibVisualOwnerActive ? (activeOwnerDir == 1 ? activeOwnerLow : activeOwnerHigh) : na
float currentFibVisualTerminalPrice = fibVisualOwnerActive ? (activeOwnerDir == 1 ? activeOwnerHigh : activeOwnerLow) : na

if fibVisualOwnerActive and not na(currentFibVisualBasePrice) and not na(currentFibVisualTerminalPrice)
    finalFibVisualMemoryValid := true
    finalFibVisualMemorySource := activeOwnerStateFinal
    finalFibVisualMemoryBasePrice := currentFibVisualBasePrice
    finalFibVisualMemoryTerminalPrice := currentFibVisualTerminalPrice
    finalFibVisualMemoryBaseTime := activeOwnerStartTime
    finalFibVisualMemoryTerminalTime := activeOwnerConfirmedEndTime

bool fibVisualMemoryActive = not fibVisualOwnerActive and finalFibVisualMemoryValid and not na(finalFibVisualMemoryBasePrice) and not na(finalFibVisualMemoryTerminalPrice) and not na(finalFibVisualMemoryBaseTime) and not na(finalFibVisualMemoryTerminalTime) and math.abs(finalFibVisualMemoryTerminalPrice - finalFibVisualMemoryBasePrice) > syminfo.mintick
bool fibVisualActive = fibVisualOwnerActive or fibVisualMemoryActive
string fibVisualSourceFinal = fibVisualOwnerActive ? fibOwnerStateFinal : fibVisualMemoryActive ? "LAST_VALID_BROKEN_CONTEXT" : "NONE"
string fibVisualStateDisplayRu = fibVisualOwnerActive ? "АКТИВНЫЙ" : fibVisualMemoryActive ? "ПОСЛ. ВАЛИДНЫЙ" : "НЕТ"
int fibVisualBaseTime = fibVisualOwnerActive ? activeOwnerStartTime : fibVisualMemoryActive ? finalFibVisualMemoryBaseTime : na
int fibVisualTerminalTime = fibVisualOwnerActive ? activeOwnerConfirmedEndTime : fibVisualMemoryActive ? finalFibVisualMemoryTerminalTime : na
float fibVisualBasePrice = fibVisualOwnerActive ? currentFibVisualBasePrice : fibVisualMemoryActive ? finalFibVisualMemoryBasePrice : na
float fibVisualTerminalPrice = fibVisualOwnerActive ? currentFibVisualTerminalPrice : fibVisualMemoryActive ? finalFibVisualMemoryTerminalPrice : na
bool fibVisualBull = fibVisualActive and not na(fibVisualBasePrice) and not na(fibVisualTerminalPrice) and fibVisualTerminalPrice > fibVisualBasePrice
float fibVisualRange = fibVisualActive and not na(fibVisualBasePrice) and not na(fibVisualTerminalPrice) ? math.abs(fibVisualTerminalPrice - fibVisualBasePrice) : na

if fibVisualActive and not na(fibVisualBaseTime) and not na(fibVisualTerminalTime) and not na(fibVisualRange) and fibVisualRange > syminfo.mintick
    float activeFib0 = na
    float activeFib50 = na
    float activeFib705 = na
    float activeFib79 = na
    float activeFib1 = na
    color fibLine0Color = color.new(color.black, fibVisualMemoryActive ? 60 : 0)
    color fibLine50Color = color.new(color.blue, fibVisualMemoryActive ? 60 : 0)
    color fibLine705Color = color.new(color.red, fibVisualMemoryActive ? 60 : 0)
    color fibLine79Color = color.new(color.red, fibVisualMemoryActive ? 75 : 0)
    color fibLine1Color = color.new(color.black, fibVisualMemoryActive ? 60 : 0)
    int fibLineWidth = fibVisualMemoryActive ? 1 : 2

    if fibVisualBull
        activeFib0 := fibVisualTerminalPrice
        activeFib50 := fibVisualTerminalPrice - fibVisualRange * 0.5
        activeFib705 := fibVisualTerminalPrice - fibVisualRange * 0.705
        activeFib79 := fibVisualTerminalPrice - fibVisualRange * 0.79
        activeFib1 := fibVisualBasePrice
    else
        activeFib0 := fibVisualTerminalPrice
        activeFib50 := fibVisualTerminalPrice + fibVisualRange * 0.5
        activeFib705 := fibVisualTerminalPrice + fibVisualRange * 0.705
        activeFib79 := fibVisualTerminalPrice + fibVisualRange * 0.79
        activeFib1 := fibVisualBasePrice

    finalFibLine0 := line.new(fibVisualBaseTime, activeFib0, fibVisualTerminalTime, activeFib0, xloc=xloc.bar_time, extend=extend.right, color=fibLine0Color, width=fibLineWidth)
    finalFibLine50 := line.new(fibVisualBaseTime, activeFib50, fibVisualTerminalTime, activeFib50, xloc=xloc.bar_time, extend=extend.right, color=fibLine50Color, width=fibLineWidth)
    finalFibLine705 := line.new(fibVisualBaseTime, activeFib705, fibVisualTerminalTime, activeFib705, xloc=xloc.bar_time, extend=extend.right, color=fibLine705Color, width=fibLineWidth)
    finalFibLine79 := line.new(fibVisualBaseTime, activeFib79, fibVisualTerminalTime, activeFib79, xloc=xloc.bar_time, extend=extend.right, color=fibLine79Color, width=fibLineWidth)
    finalFibLine1 := line.new(fibVisualBaseTime, activeFib1, fibVisualTerminalTime, activeFib1, xloc=xloc.bar_time, extend=extend.right, color=fibLine1Color, width=fibLineWidth)

float ownerProofPrice = activeOwnerStateFinal == "CURRENT" ? (activeOwnerDir == 1 ? activeOwnerHigh : activeOwnerLow) : activeOwnerIsPreviousAnchor ? (mtfPreviousPrimaryDirRaw == 1 ? mtfPreviousPrimaryHighRaw : mtfPreviousPrimaryLowRaw) : close
color ownerProofBaseColor = activeOwnerStateFinal == "CURRENT" ? color.green : activeOwnerStateFinal == "PREVIOUS_AFTER_ROLLBACK" ? color.orange : activeOwnerStateFinal == "PREVIOUS" ? color.gray : color.black
color ownerProofColor = color.new(ownerProofBaseColor, VIS_TRANS_PROOF_LABEL)
lblOwnerProof := label.new(bar_index, ownerProofPrice, "ПРОФИЛЬ: " + roleProfileProofRu + "\nТФ ГРАФИКА: " + roleDisplayProof + "\nТФ POI: " + rolePoiProof + "\nТФ ОСН.: " + rolePrimaryProof + "\nТФ ПОДТВ.: " + roleConfirmProof + "\nВЛАДЕЛЕЦ: " + activeOwnerStateDisplayRu + "\nВЛАДЕЛЕЦ FIB: " + fibOwnerStateDisplayRu + "\nFIB ВИЗ: " + fibVisualStateDisplayRu + "\nФИКСАЦИЯ ОСН.: " + currentLockStateDisplayRu + "\nСОСТ. POI: " + previousAnchorStateDisplayRu + "\nСЛЕД. ПОДТВ.: " + currentTakeoverRejectDisplayRu + "\nПЕРЕЗАПУСК: " + rearmStateDisplayRu + "\nПРИЧИНА: " + rearmReasonDisplayRu + "\nСЛОМ: " + breakStateDisplayRu, xloc=xloc.bar_index, style=label.style_label_left, color=ownerProofColor, textcolor=color.white)

// 17. TEMPORARY TIMING TRACE DEBUG TABLE - STAGE 7.2-G
var table traceTimingTable = na

if traceTimingEnabled and na(traceTimingTable)
    traceTimingTable := table.new(position.bottom_right, 2, 32, border_width=1)

if traceTimingEnabled and barstate.islast and not na(traceTimingTable)
    color traceBgColor = color.new(color.black, VIS_TRANS_TRACE_BG)
    color traceTextColor = color.new(color.white, VIS_TRANS_TRACE_TEXT)
    string protectedSourceDisplayRu = f_ruProtectedSource(mtfCurrentPrimaryProtectedSource)
    string protectedMissingReasonDisplayRu = f_ruProtectedMissingReason(mtfCurrentPrimaryProtectedMissingReason)
    table.clear(traceTimingTable, 0, 0, 1, 31)
