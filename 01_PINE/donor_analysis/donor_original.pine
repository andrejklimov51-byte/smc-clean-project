    previousAnchorBaseLine := line.new(mtfPreviousPrimaryStartTimeRaw, previousAnchorBasePrice, time, previousAnchorBasePrice, xloc=xloc.bar_time, extend=extend.right, color=color.gray, style=line.style_dashed, width=1)
    previousAnchorTerminalLine := line.new(mtfPreviousPrimaryProvisionalEndTimeRaw, previousAnchorTerminalPrice, time, previousAnchorTerminalPrice, xloc=xloc.bar_time, extend=extend.right, color=color.gray, style=line.style_dashed, width=1)
    lblPreviousAnchorBase := label.new(mtfPreviousPrimaryStartTimeRaw, previousAnchorBasePrice, rolePoiProof + " POI БАЗА", xloc=xloc.bar_time, style=mtfPreviousPrimaryDirRaw == 1 ? label.style_label_up : label.style_label_down, color=previousAnchorLabelColor, textcolor=color.white)
    lblPreviousAnchorTerminal := label.new(mtfPreviousPrimaryProvisionalEndTimeRaw, previousAnchorTerminalPrice, rolePoiProof + " POI КОНЕЦ", xloc=xloc.bar_time, style=mtfPreviousPrimaryDirRaw == 1 ? label.style_label_down : label.style_label_up, color=previousAnchorLabelColor, textcolor=color.white)

if not na(currentPrimaryBaseLine)
