        table.cell(traceTimingTable, 1, 13, str.tostring(lastActualCurrentBreakTimeCandidate) + " / " + str.tostring(lastActualCurrentBreakPriceCandidate), text_color=traceTextColor, bgcolor=traceBgColor)
        table.cell(traceTimingTable, 0, 14, "СЛОМ ОТСЛЕЖ.", text_color=traceTextColor, bgcolor=traceBgColor)
        table.cell(traceTimingTable, 1, 14, str.tostring(mtfLastPrimaryBreakTime), text_color=traceTextColor, bgcolor=traceBgColor)
        table.cell(traceTimingTable, 0, 15, "ЗАЩ. УРОВЕНЬ", text_color=traceTextColor, bgcolor=traceBgColor)
        table.cell(traceTimingTable, 1, 15, str.tostring(mtfCurrentPrimaryProtectedLevel), text_color=traceTextColor, bgcolor=traceBgColor)
        table.cell(traceTimingTable, 0, 16, "ЗАЩ. ВАЛИДЕН", text_color=traceTextColor, bgcolor=traceBgColor)
        table.cell(traceTimingTable, 1, 16, f_ruBool(mtfCurrentPrimaryProtectedValid), text_color=traceTextColor, bgcolor=traceBgColor)
        table.cell(traceTimingTable, 0, 17, "ЗАЩ. ИСТОЧНИК", text_color=traceTextColor, bgcolor=traceBgColor)
        table.cell(traceTimingTable, 1, 17, protectedSourceDisplayRu, text_color=traceTextColor, bgcolor=traceBgColor)
        table.cell(traceTimingTable, 0, 18, "ВРЕМ. 0.79", text_color=traceTextColor, bgcolor=traceBgColor)
        table.cell(traceTimingTable, 1, 18, str.tostring(mtfCurrentPrimaryBreakLevel), text_color=traceTextColor, bgcolor=traceBgColor)
        table.cell(traceTimingTable, 0, 19, "ПРИЧИНА НЕТ ЗАЩ.", text_color=traceTextColor, bgcolor=traceBgColor)
