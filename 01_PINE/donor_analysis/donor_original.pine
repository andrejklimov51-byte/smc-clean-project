//@version=6
indicator("SMC Core Detector L0 Completion Rule Reachable", overlay=true, max_labels_count=20, max_lines_count=20)

// 1. INPUTS
pivotLen = input.int(3, "Pivot Length", minval=1)
freezeAtrLen = input.int(14, "Freeze ATR Length", minval=1)
freezeAtrFactor = input.float(0.15, "Freeze Min Pullback ATR Factor", minval=0.0, maxval=2.0, step=0.05)
freezeSequenceLen = input.int(2, "Freeze Opposite Sequence Bars", minval=1, maxval=5)
dominanceRangeFrac = 0.25
minRelativeRangeFrac = 0.35

// 1.5 FIXED MTF MAP / IMPULSE SNAPSHOT
f_latest_confirmed_impulse(_pivotLen, _freezeAtrLen, _freezeAtrFactor, _freezeSequenceLen) =>
    _atrValue = ta.atr(_freezeAtrLen)
    _minFreezePullback = _atrValue * _freezeAtrFactor

    _pivotLowPrice = ta.pivotlow(low, _pivotLen, _pivotLen)
    _pivotHighPrice = ta.pivothigh(high, _pivotLen, _pivotLen)
    _newPivotLow = not na(_pivotLowPrice)
    _newPivotHigh = not na(_pivotHighPrice)

    int _pivotLowTime = _newPivotLow ? time[_pivotLen] : na
    int _pivotHighTime = _newPivotHigh ? time[_pivotLen] : na

    var int _bullBaseTime = na
    var float _bullBasePrice = na
    var int _bullTerminalTime = na
    var float _bullTerminalPrice = na
    var float _bullPostTerminalLow = na
    var int _bullPostTerminalLowTime = na
    var int _bullBearishSeq = 0

    var int _bearBaseTime = na
    var float _bearBasePrice = na
    var int _bearTerminalTime = na
    var float _bearTerminalPrice = na
    var float _bearPostTerminalHigh = na
    var int _bearPostTerminalHighTime = na
    var int _bearBullishSeq = 0

    var bool _primaryExists = false
    var int _primaryStartTime = na
    var int _primaryProvisionalEndTime = na
    var int _primaryConfirmedEndTime = na
    var float _primaryLow = na
    var float _primaryHigh = na
    var int _primaryDir = 0
    var float _primaryRange = na
    var bool _primaryConfirmed = false
    var int _primaryCompletionTime = na
    var float _primaryCompletionPrice = na
    var float _primaryCorrectionExtreme = na
    var int _primaryCorrectionTime = na

    bool _completedLegNow = false
    int _completedStartTime = na
    int _completedTerminalTime = na
    float _completedLow = na
    float _completedHigh = na
    int _completedDir = 0
    float _completedRange = na
    int _completedPublicationTime = na
    float _completedPublicationPrice = na

    if not na(_bullTerminalTime) and time > _bullTerminalTime
        if na(_bullPostTerminalLow) or low < _bullPostTerminalLow
            _bullPostTerminalLow := low
            _bullPostTerminalLowTime := time
        _bullBearishSeq := close < open ? _bullBearishSeq + 1 : 0
    else
        _bullPostTerminalLow := na
        _bullPostTerminalLowTime := na
        _bullBearishSeq := 0

    if not na(_bearTerminalTime) and time > _bearTerminalTime
        if na(_bearPostTerminalHigh) or high > _bearPostTerminalHigh
            _bearPostTerminalHigh := high
            _bearPostTerminalHighTime := time
        _bearBullishSeq := close > open ? _bearBullishSeq + 1 : 0
    else
        _bearPostTerminalHigh := na
        _bearPostTerminalHighTime := na
        _bearBullishSeq := 0

    bool _bullHasSmallPullback = not na(_bullPostTerminalLow) and not na(_bullTerminalPrice) and _bullTerminalPrice - _bullPostTerminalLow > _minFreezePullback
    bool _bearHasSmallBounce = not na(_bearPostTerminalHigh) and not na(_bearTerminalPrice) and _bearPostTerminalHigh - _bearTerminalPrice > _minFreezePullback

    bool _bullSequenceFreezeNow = not na(_bullBaseTime) and not na(_bullTerminalTime) and _bullTerminalPrice > _bullBasePrice and time > _bullTerminalTime and _bullHasSmallPullback and _bullBearishSeq >= _freezeSequenceLen
    if _bullSequenceFreezeNow
        if not _completedLegNow or _bullTerminalTime > _completedTerminalTime
            _completedLegNow := true
            _completedStartTime := _bullBaseTime
            _completedTerminalTime := _bullTerminalTime
            _completedLow := _bullBasePrice
            _completedHigh := _bullTerminalPrice
            _completedDir := 1
            _completedRange := _bullTerminalPrice - _bullBasePrice
            _completedPublicationTime := time
            _completedPublicationPrice := close

    bool _bearSequenceFreezeNow = not na(_bearBaseTime) and not na(_bearTerminalTime) and _bearBasePrice > _bearTerminalPrice and time > _bearTerminalTime and _bearHasSmallBounce and _bearBullishSeq >= _freezeSequenceLen
    if _bearSequenceFreezeNow
        if not _completedLegNow or _bearTerminalTime > _completedTerminalTime
            _completedLegNow := true
            _completedStartTime := _bearBaseTime
            _completedTerminalTime := _bearTerminalTime
            _completedLow := _bearTerminalPrice
            _completedHigh := _bearBasePrice
            _completedDir := -1
            _completedRange := _bearBasePrice - _bearTerminalPrice
            _completedPublicationTime := time
            _completedPublicationPrice := close

    if _newPivotLow
        bool _bearHigherLowFreeze = not na(_bearBaseTime) and not na(_bearTerminalTime) and _pivotLowTime > _bearTerminalTime and _pivotLowPrice > _bearTerminalPrice and _bearHasSmallBounce
        if _bearHigherLowFreeze
            float _bearLegRange = _bearBasePrice - _bearTerminalPrice
            if _bearLegRange > syminfo.mintick
                if not _completedLegNow or _bearTerminalTime > _completedTerminalTime
                    _completedLegNow := true
                    _completedStartTime := _bearBaseTime
                    _completedTerminalTime := _bearTerminalTime
                    _completedLow := _bearTerminalPrice
                    _completedHigh := _bearBasePrice
                    _completedDir := -1
                    _completedRange := _bearLegRange
                    _completedPublicationTime := time
                    _completedPublicationPrice := close

        _bullBaseTime := _pivotLowTime
        _bullBasePrice := _pivotLowPrice
        _bullTerminalTime := na
        _bullTerminalPrice := na
        _bullPostTerminalLow := na
        _bullPostTerminalLowTime := na
        _bullBearishSeq := 0

        if not na(_bearBaseTime) and _bearBaseTime < _pivotLowTime
            if na(_bearTerminalTime) or _pivotLowPrice < _bearTerminalPrice
                _bearTerminalTime := _pivotLowTime
                _bearTerminalPrice := _pivotLowPrice
                _bearPostTerminalHigh := na
                _bearPostTerminalHighTime := na
                _bearBullishSeq := 0

    if _newPivotHigh
        bool _bullLowerHighFreeze = not na(_bullBaseTime) and not na(_bullTerminalTime) and _pivotHighTime > _bullTerminalTime and _pivotHighPrice < _bullTerminalPrice and _bullHasSmallPullback
        if _bullLowerHighFreeze
            float _bullLegRange = _bullTerminalPrice - _bullBasePrice
            if _bullLegRange > syminfo.mintick
                if not _completedLegNow or _bullTerminalTime > _completedTerminalTime
                    _completedLegNow := true
                    _completedStartTime := _bullBaseTime
                    _completedTerminalTime := _bullTerminalTime
                    _completedLow := _bullBasePrice
                    _completedHigh := _bullTerminalPrice
                    _completedDir := 1
                    _completedRange := _bullLegRange
                    _completedPublicationTime := time
                    _completedPublicationPrice := close

        _bearBaseTime := _pivotHighTime
        _bearBasePrice := _pivotHighPrice
        _bearTerminalTime := na
        _bearTerminalPrice := na
        _bearPostTerminalHigh := na
        _bearPostTerminalHighTime := na
        _bearBullishSeq := 0

        if not na(_bullBaseTime) and _bullBaseTime < _pivotHighTime
            if na(_bullTerminalTime) or _pivotHighPrice > _bullTerminalPrice
                _bullTerminalTime := _pivotHighTime
                _bullTerminalPrice := _pivotHighPrice
                _bullPostTerminalLow := na
                _bullPostTerminalLowTime := na
                _bullBearishSeq := 0

    bool _newerCompletedLeg = _completedLegNow and _completedRange > syminfo.mintick and (not _primaryExists or na(_primaryProvisionalEndTime) or _completedTerminalTime > _primaryProvisionalEndTime)
    if _newerCompletedLeg
        _primaryExists := true
        _primaryStartTime := _completedStartTime
        _primaryProvisionalEndTime := _completedTerminalTime
        _primaryConfirmedEndTime := na
        _primaryLow := _completedLow
        _primaryHigh := _completedHigh
        _primaryDir := _completedDir
        _primaryRange := _completedRange
        _primaryConfirmed := false
        _primaryCompletionTime := _completedPublicationTime
        _primaryCompletionPrice := _completedPublicationPrice
        _primaryCorrectionExtreme := _completedDir == 1 ? _bullPostTerminalLow : _bearPostTerminalHigh
        _primaryCorrectionTime := _completedDir == 1 ? _bullPostTerminalLowTime : _bearPostTerminalHighTime
        float _primaryCorrectionThresholdAtBirth = _completedDir == 1 ? _completedHigh - _completedRange * 0.5 : _completedLow + _completedRange * 0.5
        bool _primaryCorrectionReachedAtBirth = _completedDir == 1 ? not na(_primaryCorrectionExtreme) and _primaryCorrectionExtreme <= _primaryCorrectionThresholdAtBirth : not na(_primaryCorrectionExtreme) and _primaryCorrectionExtreme >= _primaryCorrectionThresholdAtBirth
        if _primaryCorrectionReachedAtBirth
            _primaryConfirmed := true
            _primaryConfirmedEndTime := na(_primaryCorrectionTime) ? _primaryCompletionTime : _primaryCorrectionTime

    if _primaryExists and not _primaryConfirmed and not na(_primaryProvisionalEndTime) and time > _primaryProvisionalEndTime
        if _primaryDir == 1
            if na(_primaryCorrectionExtreme) or low < _primaryCorrectionExtreme
                _primaryCorrectionExtreme := low
                _primaryCorrectionTime := time
        else if _primaryDir == -1
            if na(_primaryCorrectionExtreme) or high > _primaryCorrectionExtreme
                _primaryCorrectionExtreme := high
                _primaryCorrectionTime := time

    bool _bullConfirmedNow = _primaryExists and not _primaryConfirmed and _primaryDir == 1 and _primaryRange > syminfo.mintick and not na(_primaryCorrectionExtreme) and _primaryCorrectionExtreme <= _primaryHigh - _primaryRange * 0.5
    bool _bearConfirmedNow = _primaryExists and not _primaryConfirmed and _primaryDir == -1 and _primaryRange > syminfo.mintick and not na(_primaryCorrectionExtreme) and _primaryCorrectionExtreme >= _primaryLow + _primaryRange * 0.5
    if _bullConfirmedNow or _bearConfirmedNow
        _primaryConfirmed := true
        _primaryConfirmedEndTime := na(_primaryCorrectionTime) ? time : _primaryCorrectionTime

    [_primaryExists and _primaryConfirmed, _primaryStartTime, _primaryProvisionalEndTime, _primaryConfirmedEndTime, _primaryLow, _primaryHigh, _primaryDir, _primaryRange, _primaryCompletionTime, _primaryCompletionPrice]

// 2. CORE SERIES
currentChartTimeframe = timeframe.period
chartTimeframeSeconds = timeframe.in_seconds(timeframe.period)
profileId = "PROFILE_4H_POI_1H_PRIMARY_15M_CONFIRM"
profileLabel = "4H POI -> 1H PRIMARY -> 15m CONFIRM"
profilePoiTimeframe = "240"
profilePrimaryTimeframe = "60"
profileConfirmTimeframe = "15"
profilePoiLabel = "4H"
profilePrimaryLabel = "1H"
profileConfirmLabel = "15m"
anchorTimeframe = profilePoiTimeframe
structuralTimeframe = profilePrimaryTimeframe
confirmTimeframe = profileConfirmTimeframe
mtfMappingRule = profileLabel
roleProfileProof = profileLabel
roleDisplayProof = currentChartTimeframe
rolePoiProof = profilePoiLabel
rolePrimaryProof = profilePrimaryLabel
roleConfirmProof = profileConfirmLabel
roleProfileProofRu = "4H POI -> 1H ОСН. -> 15m ПОДТВ."
// 6. ACTIVE VISUALS
const int VIS_TRANS_POI_BOX = 88
const int VIS_TRANS_PRIMARY_BOX = 88
const int VIS_TRANS_PROOF_LABEL = 72
const int VIS_TRANS_STATE_LABEL = 25
const int VIS_TRANS_TRACE_BG = 92
const int VIS_TRANS_TRACE_TEXT = 15
const bool traceTimingEnabled = false
const bool traceTimingCompact = true
const bool protectedLevelDebugEnabled = true
const bool protectedLevelShow079Compare = true

// RU DISPLAY HELPERS — VISUAL TEXT ONLY
f_ruBool(_b) =>
    _b ? "ДА" : "НЕТ"

f_ruOwnerState(_s) =>
    _s == "CURRENT" ? "ТЕКУЩИЙ" :
     _s == "PREVIOUS" ? "ПРЕДЫДУЩИЙ" :
     _s == "PREVIOUS_AFTER_ROLLBACK" ? "ПРЕД. ПОСЛЕ ОТКАТА" :
     _s == "NONE" ? "НЕТ" : _s

f_ruLockState(_s) =>
    _s == "LOCKED" ? "ЗАФИКСИРОВАН" :
     _s == "BROKEN" ? "СЛОМАН" :
     _s == "INACTIVE" ? "НЕАКТИВЕН" :
     _s == "NONE" ? "НЕТ" : _s

f_ruPoiState(_s) =>
    _s == "REFERENCE" ? "ОПОРНЫЙ" :
     _s == "ACTIVE" ? "АКТИВНЫЙ" :
     _s == "BROKEN" ? "СЛОМАН" :
     _s == "STALE" ? "УСТАРЕЛ" :
     _s == "NONE" ? "НЕТ" : _s

f_ruNextConfirm(_s) =>
    _s == "TAKEOVER_ALLOWED" ? "ПЕРЕХВАТ РАЗРЕШЁН" :
     _s == "PREVIOUS_BROKEN" ? "ПРЕДЫДУЩИЙ СЛОМАН" :
     _s == "OUT_OF_ANCHOR_EXPANSION" ? "ВНЕ ЯКОРЯ" :
     _s == "SAME_AS_TRACKED" ? "КАК ОТСЛЕЖ." :
     _s == "NO_ANCHOR" ? "НЕТ ЯКОРЯ" :
     _s == "WAIT_NEW_ANCHOR" ? "ЖДЁМ НОВЫЙ ЯКОРЬ" :
     _s == "RAW_INVALID" ? "НЕВАЛИДНЫЙ RAW" :
     _s == "NOT_NESTED" ? "НЕ ВНУТРИ POI" :
     _s == "SAME_AS_ANCHOR" ? "КАК ЯКОРЬ" :
     _s == "NOT_LATER" ? "НЕ ПОЗЖЕ ТЕКУЩ." :
     _s == "RANGE_TOO_SMALL" ? "ДИАПАЗОН МАЛ" :
     _s == "INTERNAL_MICRO_LEG" ? "ВНУТР. МИКРО-ИМПУЛЬС" :
     _s == "CORRECTION_INVALID" ? "КОРРЕКЦИЯ НЕВАЛИДНА" :
     _s == "NO_DOMINANCE" ? "НЕТ ДОМИНИРОВАНИЯ" :
     _s == "UNKNOWN" ? "НЕИЗВЕСТНО" :
     _s == "NONE" ? "НЕТ" : _s

f_ruRearmState(_s) =>
    _s == "REARM_LOCKED_CURRENT" ? "ТЕКУЩИЙ ЗАФИКС." :
     _s == "WAIT_PRIMARY_IN_POI" ? "ЖДЁМ 1H В POI" :
     _s == "WAIT_NEW_POI" ? "ЖДЁМ НОВЫЙ POI" :
     _s == "REARM_NONE_OFF" ? "ВЫКЛ." :
     _s == "NONE" ? "НЕТ" : _s

f_ruRearmReason(_s) =>
    _s == "1H_PRIMARY_OWNER_ACTIVE" ? "1H ОСН. АКТИВЕН" :
     _s == "PRIMARY_BROKEN_ROLLBACK_TO_POI" ? "СЛОМ ОСН. -> ОТКАТ К POI" :
     _s == "PRIMARY_BROKEN_POI_INVALID" ? "СЛОМ ОСН., POI НЕВАЛИДЕН" :
     _s == "NO_VALID_4H_POI" ? "НЕТ ВАЛИДНОГО 4H POI" :
     _s == "VALID_4H_POI_WAIT_1H_PRIMARY" ? "ЖДЁМ 1H ОСН. В POI" :
     _s == "4H_POI_OWNER_WAIT_1H_PRIMARY" ? "POI ВЛАДЕЛЕЦ, ЖДЁМ 1H" :
     _s == "NO_REARM_NEEDED" ? "ПЕРЕЗАПУСК НЕ НУЖЕН" : _s

f_ruBreakState(_s) =>
    _s == "NO_BREAK" ? "НЕТ СЛОМА" :
     _s == "BROKEN_PRIMARY_ROLLBACK_TO_POI" ? "СЛОМ ОСН. -> ОТКАТ К POI" :
     _s == "BROKEN_PRIMARY_OWNER_NONE" ? "СЛОМ ОСН. -> ВЛАДЕЛЕЦ НЕТ" :
     _s == "BROKEN_PRIMARY" ? "СЛОМ ОСН." : _s

f_ruBreakMode(_s) =>
    _s == "CURRENT_PRIMARY_FIB79_15M_WICK" ? "ТЕКУЩАЯ ОСН. FIB79 / 15m ТЕНЬ" :
     _s == "NO_BREAK_LEVEL" ? "НЕТ УРОВНЯ СЛОМА" : _s

f_ruProtectedSource(_s) =>
    _s == "15M_SWING_LOW_IN_1H_PRIMARY" ? "15m SWING LOW В 1H ОСН." :
     _s == "15M_SWING_HIGH_IN_1H_PRIMARY" ? "15m SWING HIGH В 1H ОСН." :
     _s == "NO_PROTECTED_SWING" ? "НЕТ ЗАЩ. SWING" :
     _s == "NONE" ? "НЕТ" : _s

f_ruProtectedMissingReason(_s) =>
    _s == "NO_CURRENT_PRIMARY" ? "НЕТ ТЕКУЩ. ОСН." :
     _s == "PRIMARY_CONTEXT_INCOMPLETE" ? "КОНТЕКСТ ОСН. НЕПОЛОН" :
     _s == "NO_15M_SWING_LOW" ? "НЕТ 15m SWING LOW" :
     _s == "NO_15M_SWING_HIGH" ? "НЕТ 15m SWING HIGH" :
     _s == "SWING_BEFORE_PRIMARY_LOCK" ? "SWING ДО ФИКСАЦИИ ОСН." :
     _s == "SWING_OUTSIDE_PRIMARY_RANGE" ? "SWING ВНЕ ДИАПАЗОНА ОСН." :
     _s == "NONE" ? "НЕТ" : _s

var line previousAnchorBaseLine = na
var line previousAnchorTerminalLine = na
var label lblPreviousAnchorBase = na
var label lblPreviousAnchorTerminal = na
var line currentPrimaryBaseLine = na
var line currentPrimaryTerminalLine = na
var label lblCurrentPrimaryBase = na
var label lblCurrentPrimaryTerminal = na
var label lblCurrentPrimaryState = na
var label lblOwnerProof = na
var line finalFibLine0 = na
var line finalFibLine50 = na
var line finalFibLine705 = na
var line finalFibLine79 = na
var line finalFibLine1 = na
var line finalPrimaryBreakLine = na
var label finalLblPrimaryBreak = na
var line finalProtectedLevelLine = na
var label finalLblProtectedLevel = na
var line finalTemp079Line = na
var label finalLblTemp079 = na
var int protectedDebugTrackedPrimaryStartTime = na
var int protectedDebugTrackedPrimaryConfirmedEndTime = na
var int protectedDebugTrackedPrimaryDir = 0
var float protectedDebugHeldLevel = na
var int protectedDebugHeldTime = na
var bool protectedDebugHeldValid = false
var string protectedDebugHeldSource = "NONE"
var bool finalFibVisualMemoryValid = false
var string finalFibVisualMemorySource = "NONE"
var float finalFibVisualMemoryBasePrice = na
var float finalFibVisualMemoryTerminalPrice = na
var int finalFibVisualMemoryBaseTime = na
var int finalFibVisualMemoryTerminalTime = na

var bool mtfCurrentPrimaryExists = false
var int mtfCurrentPrimaryStartTime = na
var int mtfCurrentPrimaryProvisionalEndTime = na
var int mtfCurrentPrimaryConfirmedEndTime = na
var float mtfCurrentPrimaryLow = na
var float mtfCurrentPrimaryHigh = na
var int mtfCurrentPrimaryDir = 0
var float mtfCurrentPrimaryRange = na
var int mtfCurrentPrimaryCompletionTime = na
var float mtfCurrentPrimaryCompletionPrice = na
var bool mtfCurrentPrimaryActive = false
var bool mtfCurrentPrimaryBroken = false
var bool mtfRollbackToPreviousAnchor = false
var int mtfTrackedAnchorStartTime = na
var int mtfTrackedAnchorConfirmedEndTime = na
var int mtfTrackedAnchorDir = 0
var int mtfLastPrimaryBreakTime = na

// 16. FIXED MTF PREVIOUS/CURRENT PRIMARY + BREAK ROLLBACK ARCHITECTURE
[mtfPreviousPrimaryAnchorExistsRaw, mtfPreviousPrimaryStartTimeRaw, mtfPreviousPrimaryProvisionalEndTimeRaw, mtfPreviousPrimaryConfirmedEndTimeRaw, mtfPreviousPrimaryLowRaw, mtfPreviousPrimaryHighRaw, mtfPreviousPrimaryDirRaw, mtfPreviousPrimaryRangeRaw, mtfPreviousPrimaryCompletionTimeRaw, mtfPreviousPrimaryCompletionPriceRaw] = request.security(syminfo.tickerid, anchorTimeframe, f_latest_confirmed_impulse(pivotLen, freezeAtrLen, freezeAtrFactor, freezeSequenceLen), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
[mtfCurrentPrimaryExistsRaw, mtfCurrentPrimaryStartTimeRaw, mtfCurrentPrimaryProvisionalEndTimeRaw, mtfCurrentPrimaryConfirmedEndTimeRaw, mtfCurrentPrimaryLowRaw, mtfCurrentPrimaryHighRaw, mtfCurrentPrimaryDirRaw, mtfCurrentPrimaryRangeRaw, mtfCurrentPrimaryCompletionTimeRaw, mtfCurrentPrimaryCompletionPriceRaw] = request.security(syminfo.tickerid, structuralTimeframe, f_latest_confirmed_impulse(pivotLen, freezeAtrLen, freezeAtrFactor, freezeSequenceLen), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

bool previousPrimaryAnchorExistsNow = mtfPreviousPrimaryAnchorExistsRaw and not na(mtfPreviousPrimaryStartTimeRaw) and not na(mtfPreviousPrimaryProvisionalEndTimeRaw) and not na(mtfPreviousPrimaryConfirmedEndTimeRaw) and not na(mtfPreviousPrimaryLowRaw) and not na(mtfPreviousPrimaryHighRaw) and mtfPreviousPrimaryDirRaw != 0 and not na(mtfPreviousPrimaryRangeRaw) and mtfPreviousPrimaryRangeRaw > syminfo.mintick
bool currentPrimaryRawExistsNow = mtfCurrentPrimaryExistsRaw and not na(mtfCurrentPrimaryStartTimeRaw) and not na(mtfCurrentPrimaryProvisionalEndTimeRaw) and not na(mtfCurrentPrimaryConfirmedEndTimeRaw) and not na(mtfCurrentPrimaryLowRaw) and not na(mtfCurrentPrimaryHighRaw) and mtfCurrentPrimaryDirRaw != 0 and not na(mtfCurrentPrimaryRangeRaw) and mtfCurrentPrimaryRangeRaw > syminfo.mintick
bool currentPrimaryNestedInAnchor = previousPrimaryAnchorExistsNow and currentPrimaryRawExistsNow and mtfCurrentPrimaryStartTimeRaw >= mtfPreviousPrimaryStartTimeRaw and mtfCurrentPrimaryLowRaw >= mtfPreviousPrimaryLowRaw - syminfo.mintick and mtfCurrentPrimaryHighRaw <= mtfPreviousPrimaryHighRaw + syminfo.mintick
bool currentPrimaryDistinctFromAnchor = currentPrimaryNestedInAnchor and (mtfCurrentPrimaryStartTimeRaw != mtfPreviousPrimaryStartTimeRaw or mtfCurrentPrimaryConfirmedEndTimeRaw != mtfPreviousPrimaryConfirmedEndTimeRaw or mtfCurrentPrimaryDirRaw != mtfPreviousPrimaryDirRaw or math.abs(mtfCurrentPrimaryRangeRaw - mtfPreviousPrimaryRangeRaw) > syminfo.mintick)
bool currentPrimaryValidNow = currentPrimaryNestedInAnchor and currentPrimaryDistinctFromAnchor
bool currentPrimaryStructurallyValid = previousPrimaryAnchorExistsNow and currentPrimaryRawExistsNow and currentPrimaryNestedInAnchor and currentPrimaryDistinctFromAnchor
bool currentPrimaryCorrectionValid = currentPrimaryStructurallyValid and not na(mtfCurrentPrimaryConfirmedEndTimeRaw)
bool trackedCurrentPrimaryExistsNow = mtfCurrentPrimaryExists and not na(mtfCurrentPrimaryStartTime) and not na(mtfCurrentPrimaryProvisionalEndTime) and not na(mtfCurrentPrimaryConfirmedEndTime) and not na(mtfCurrentPrimaryLow) and not na(mtfCurrentPrimaryHigh) and mtfCurrentPrimaryDir != 0 and not na(mtfCurrentPrimaryRange) and mtfCurrentPrimaryRange > syminfo.mintick
bool currentPrimaryTrackedOwnerExists = trackedCurrentPrimaryExistsNow and mtfCurrentPrimaryActive and not mtfCurrentPrimaryBroken
bool rawCurrentPrimaryDistinctFromTracked = currentPrimaryStructurallyValid and (not trackedCurrentPrimaryExistsNow or mtfCurrentPrimaryStartTimeRaw != mtfCurrentPrimaryStartTime or mtfCurrentPrimaryProvisionalEndTimeRaw != mtfCurrentPrimaryProvisionalEndTime or mtfCurrentPrimaryConfirmedEndTimeRaw != mtfCurrentPrimaryConfirmedEndTime or mtfCurrentPrimaryDirRaw != mtfCurrentPrimaryDir or math.abs(mtfCurrentPrimaryRangeRaw - mtfCurrentPrimaryRange) > syminfo.mintick)
int rawCurrentPrimarySortTime = currentPrimaryStructurallyValid ? mtfCurrentPrimaryConfirmedEndTimeRaw : na
int trackedCurrentPrimarySortTime = trackedCurrentPrimaryExistsNow ? mtfCurrentPrimaryConfirmedEndTime : na
bool currentPrimaryLaterThanTracked = currentPrimaryStructurallyValid and (not trackedCurrentPrimaryExistsNow or (not na(rawCurrentPrimarySortTime) and not na(trackedCurrentPrimarySortTime) and rawCurrentPrimarySortTime > trackedCurrentPrimarySortTime) or (not na(rawCurrentPrimarySortTime) and not na(trackedCurrentPrimarySortTime) and rawCurrentPrimarySortTime == trackedCurrentPrimarySortTime and mtfCurrentPrimaryProvisionalEndTimeRaw > mtfCurrentPrimaryProvisionalEndTime) or (not na(rawCurrentPrimarySortTime) and not na(trackedCurrentPrimarySortTime) and rawCurrentPrimarySortTime == trackedCurrentPrimarySortTime and mtfCurrentPrimaryProvisionalEndTimeRaw == mtfCurrentPrimaryProvisionalEndTime and mtfCurrentPrimaryStartTimeRaw > mtfCurrentPrimaryStartTime))
float trackedCurrentPrimaryRange = trackedCurrentPrimaryExistsNow ? mtfCurrentPrimaryRange : na
float trackedCurrentPrimaryDirectionalTerminal = trackedCurrentPrimaryExistsNow ? mtfCurrentPrimaryDir == 1 ? mtfCurrentPrimaryHigh : mtfCurrentPrimaryLow : na
bool currentPrimaryMinRangeOk = not trackedCurrentPrimaryExistsNow or (not na(trackedCurrentPrimaryRange) and mtfCurrentPrimaryRangeRaw >= trackedCurrentPrimaryRange * minRelativeRangeFrac)
bool currentPrimaryTerminalExpansionOk = not trackedCurrentPrimaryExistsNow or (not na(trackedCurrentPrimaryRange) and not na(trackedCurrentPrimaryDirectionalTerminal) and (mtfCurrentPrimaryDirRaw == 1 ? mtfCurrentPrimaryHighRaw > trackedCurrentPrimaryDirectionalTerminal + trackedCurrentPrimaryRange * dominanceRangeFrac : mtfCurrentPrimaryLowRaw < trackedCurrentPrimaryDirectionalTerminal - trackedCurrentPrimaryRange * dominanceRangeFrac))
bool currentPrimaryRangeDominanceOk = not trackedCurrentPrimaryExistsNow or (not na(trackedCurrentPrimaryRange) and mtfCurrentPrimaryRangeRaw >= trackedCurrentPrimaryRange * (1 + dominanceRangeFrac))
bool currentPrimaryFullyInsideTracked = trackedCurrentPrimaryExistsNow and mtfCurrentPrimaryLowRaw >= mtfCurrentPrimaryLow - syminfo.mintick and mtfCurrentPrimaryHighRaw <= mtfCurrentPrimaryHigh + syminfo.mintick
bool currentPrimaryIsInternalMicroLeg = trackedCurrentPrimaryExistsNow and currentPrimaryFullyInsideTracked and not currentPrimaryRangeDominanceOk
bool currentPrimaryDominatesTrackedOwner = not trackedCurrentPrimaryExistsNow or (currentPrimaryLaterThanTracked and currentPrimaryMinRangeOk and not currentPrimaryIsInternalMicroLeg and (not currentPrimaryTrackedOwnerExists or currentPrimaryTerminalExpansionOk or currentPrimaryRangeDominanceOk))
bool currentPrimaryTakeoverAllowed = previousPrimaryAnchorExistsNow and currentPrimaryStructurallyValid and currentPrimaryCorrectionValid and rawCurrentPrimaryDistinctFromTracked and currentPrimaryDominatesTrackedOwner and not currentPrimaryIsInternalMicroLeg
bool currentPrimaryNeedsRefresh = currentPrimaryTakeoverAllowed
bool previousAnchorExistsFinal = previousPrimaryAnchorExistsNow
bool previousAnchorBrokenByClose = previousAnchorExistsFinal and ((mtfPreviousPrimaryDirRaw == 1 and close < mtfPreviousPrimaryLowRaw - syminfo.mintick) or (mtfPreviousPrimaryDirRaw == -1 and close > mtfPreviousPrimaryHighRaw + syminfo.mintick))
bool previousAnchorOutOfRangeByPrice = previousAnchorExistsFinal and (high > mtfPreviousPrimaryHighRaw + syminfo.mintick or low < mtfPreviousPrimaryLowRaw - syminfo.mintick)
bool rawCurrentAbovePreviousAnchor = previousAnchorExistsFinal and currentPrimaryRawExistsNow and mtfCurrentPrimaryHighRaw > mtfPreviousPrimaryHighRaw + syminfo.mintick
bool rawCurrentBelowPreviousAnchor = previousAnchorExistsFinal and currentPrimaryRawExistsNow and mtfCurrentPrimaryLowRaw < mtfPreviousPrimaryLowRaw - syminfo.mintick
bool rawCurrentOutOfPreviousAnchor = rawCurrentAbovePreviousAnchor or rawCurrentBelowPreviousAnchor
bool rawCurrentOutOfAnchorExpansion = previousAnchorExistsFinal and currentPrimaryRawExistsNow and ((mtfPreviousPrimaryDirRaw == 1 and rawCurrentBelowPreviousAnchor) or (mtfPreviousPrimaryDirRaw == -1 and rawCurrentAbovePreviousAnchor))
bool previousAnchorStaleByExpansion = rawCurrentOutOfAnchorExpansion
bool previousAnchorActiveValid = previousAnchorExistsFinal and not previousAnchorBrokenByClose and not previousAnchorStaleByExpansion
bool previousOwnerFallbackAllowed = previousAnchorActiveValid and not mtfRollbackToPreviousAnchor
string currentTakeoverRejectReason = currentPrimaryTakeoverAllowed ? "TAKEOVER_ALLOWED" : previousAnchorBrokenByClose ? "PREVIOUS_BROKEN" : rawCurrentOutOfAnchorExpansion ? "OUT_OF_ANCHOR_EXPANSION" : not previousAnchorExistsFinal ? "NO_ANCHOR" : not previousAnchorActiveValid and not currentPrimaryRawExistsNow ? "WAIT_NEW_ANCHOR" : not currentPrimaryRawExistsNow ? "RAW_INVALID" : not currentPrimaryNestedInAnchor ? "NOT_NESTED" : not currentPrimaryDistinctFromAnchor ? "SAME_AS_ANCHOR" : trackedCurrentPrimaryExistsNow and not rawCurrentPrimaryDistinctFromTracked ? "SAME_AS_TRACKED" : trackedCurrentPrimaryExistsNow and not currentPrimaryLaterThanTracked ? "NOT_LATER" : not currentPrimaryMinRangeOk ? "RANGE_TOO_SMALL" : currentPrimaryIsInternalMicroLeg ? "INTERNAL_MICRO_LEG" : not currentPrimaryCorrectionValid ? "CORRECTION_INVALID" : not currentPrimaryDominatesTrackedOwner ? "NO_DOMINANCE" : "UNKNOWN"

bool mtfAnchorChanged = previousPrimaryAnchorExistsNow and (mtfTrackedAnchorStartTime != mtfPreviousPrimaryStartTimeRaw or mtfTrackedAnchorConfirmedEndTime != mtfPreviousPrimaryConfirmedEndTimeRaw or mtfTrackedAnchorDir != mtfPreviousPrimaryDirRaw)
if mtfAnchorChanged or not previousPrimaryAnchorExistsNow
    mtfCurrentPrimaryExists := false
    mtfCurrentPrimaryStartTime := na
    mtfCurrentPrimaryProvisionalEndTime := na
    mtfCurrentPrimaryConfirmedEndTime := na
    mtfCurrentPrimaryLow := na
    mtfCurrentPrimaryHigh := na
    mtfCurrentPrimaryDir := 0
    mtfCurrentPrimaryRange := na
    mtfCurrentPrimaryCompletionTime := na
    mtfCurrentPrimaryCompletionPrice := na
    mtfCurrentPrimaryActive := false
    mtfCurrentPrimaryBroken := false
    mtfRollbackToPreviousAnchor := false
    mtfLastPrimaryBreakTime := na
    if not na(finalPrimaryBreakLine)
        line.delete(finalPrimaryBreakLine)
        finalPrimaryBreakLine := na
    if not na(finalLblPrimaryBreak)
        label.delete(finalLblPrimaryBreak)
        finalLblPrimaryBreak := na

if previousPrimaryAnchorExistsNow
    mtfTrackedAnchorStartTime := mtfPreviousPrimaryStartTimeRaw
    mtfTrackedAnchorConfirmedEndTime := mtfPreviousPrimaryConfirmedEndTimeRaw
    mtfTrackedAnchorDir := mtfPreviousPrimaryDirRaw

if currentPrimaryNeedsRefresh
    if not na(finalPrimaryBreakLine)
        line.delete(finalPrimaryBreakLine)
        finalPrimaryBreakLine := na
    if not na(finalLblPrimaryBreak)
        label.delete(finalLblPrimaryBreak)
        finalLblPrimaryBreak := na
    mtfLastPrimaryBreakTime := na
    mtfCurrentPrimaryExists := true
    mtfCurrentPrimaryStartTime := mtfCurrentPrimaryStartTimeRaw
    mtfCurrentPrimaryProvisionalEndTime := mtfCurrentPrimaryProvisionalEndTimeRaw
    mtfCurrentPrimaryConfirmedEndTime := mtfCurrentPrimaryConfirmedEndTimeRaw
    mtfCurrentPrimaryLow := mtfCurrentPrimaryLowRaw
    mtfCurrentPrimaryHigh := mtfCurrentPrimaryHighRaw
    mtfCurrentPrimaryDir := mtfCurrentPrimaryDirRaw
    mtfCurrentPrimaryRange := mtfCurrentPrimaryRangeRaw
    mtfCurrentPrimaryCompletionTime := mtfCurrentPrimaryCompletionTimeRaw
    mtfCurrentPrimaryCompletionPrice := mtfCurrentPrimaryCompletionPriceRaw
    mtfCurrentPrimaryActive := true
    mtfCurrentPrimaryBroken := false
    mtfRollbackToPreviousAnchor := false

int confirmTimeframeSeconds = timeframe.in_seconds(confirmTimeframe)
bool confirmUsesLowerTf = chartTimeframeSeconds > confirmTimeframeSeconds
array<float> confirmLowArray = array.new_float()
array<float> confirmHighArray = array.new_float()
array<int> confirmTimeArray = array.new_int()
if confirmUsesLowerTf
    confirmLowArray := request.security_lower_tf(syminfo.tickerid, confirmTimeframe, low)
    confirmHighArray := request.security_lower_tf(syminfo.tickerid, confirmTimeframe, high)
    confirmTimeArray := request.security_lower_tf(syminfo.tickerid, confirmTimeframe, time)
else
    array.push(confirmLowArray, low)
    array.push(confirmHighArray, high)
    array.push(confirmTimeArray, time)

[confirmLatestSwingLowPrice, confirmLatestSwingLowTime, confirmLatestSwingHighPrice, confirmLatestSwingHighTime] = request.security(syminfo.tickerid, confirmTimeframe, [ta.valuewhen(low[1] < low[2] and low[1] < low, low[1], 0), ta.valuewhen(low[1] < low[2] and low[1] < low, time[1], 0), ta.valuewhen(high[1] > high[2] and high[1] > high, high[1], 0), ta.valuewhen(high[1] > high[2] and high[1] > high, time[1], 0)], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

float mtfCurrentPrimaryProtectedLevel = na
int mtfCurrentPrimaryProtectedTime = na
bool mtfCurrentPrimaryProtectedValid = false
string mtfCurrentPrimaryProtectedSource = "NONE"
string mtfCurrentPrimaryProtectedMode = "15M_INTERNAL_SWING_DEBUG"
string mtfCurrentPrimaryProtectedMissingReason = "NO_CURRENT_PRIMARY"

bool protectedDebugCurrentContextReady = mtfCurrentPrimaryExists and not na(mtfCurrentPrimaryStartTime) and not na(mtfCurrentPrimaryConfirmedEndTime) and mtfCurrentPrimaryDir != 0
bool protectedBullSwingPresent = not na(confirmLatestSwingLowPrice) and not na(confirmLatestSwingLowTime)
bool protectedBearSwingPresent = not na(confirmLatestSwingHighPrice) and not na(confirmLatestSwingHighTime)
bool bullProtectedTimeValid = protectedDebugCurrentContextReady and mtfCurrentPrimaryDir == 1 and protectedBullSwingPresent and confirmLatestSwingLowTime >= mtfCurrentPrimaryStartTime and confirmLatestSwingLowTime >= mtfCurrentPrimaryConfirmedEndTime
bool bearProtectedTimeValid = protectedDebugCurrentContextReady and mtfCurrentPrimaryDir == -1 and protectedBearSwingPresent and confirmLatestSwingHighTime >= mtfCurrentPrimaryStartTime and confirmLatestSwingHighTime >= mtfCurrentPrimaryConfirmedEndTime
bool bullProtectedLevelCandidateValid = bullProtectedTimeValid and confirmLatestSwingLowPrice >= mtfCurrentPrimaryLow - syminfo.mintick and confirmLatestSwingLowPrice <= mtfCurrentPrimaryHigh + syminfo.mintick
bool bearProtectedLevelCandidateValid = bearProtectedTimeValid and confirmLatestSwingHighPrice >= mtfCurrentPrimaryLow - syminfo.mintick and confirmLatestSwingHighPrice <= mtfCurrentPrimaryHigh + syminfo.mintick
bool protectedDebugContextChanged = protectedDebugCurrentContextReady and (mtfCurrentPrimaryStartTime != protectedDebugTrackedPrimaryStartTime or mtfCurrentPrimaryConfirmedEndTime != protectedDebugTrackedPrimaryConfirmedEndTime or mtfCurrentPrimaryDir != protectedDebugTrackedPrimaryDir)

if not protectedDebugCurrentContextReady
    protectedDebugTrackedPrimaryStartTime := na
    protectedDebugTrackedPrimaryConfirmedEndTime := na
    protectedDebugTrackedPrimaryDir := 0
    protectedDebugHeldLevel := na
    protectedDebugHeldTime := na
    protectedDebugHeldValid := false
    protectedDebugHeldSource := "NONE"
else if protectedDebugContextChanged
    protectedDebugTrackedPrimaryStartTime := mtfCurrentPrimaryStartTime
    protectedDebugTrackedPrimaryConfirmedEndTime := mtfCurrentPrimaryConfirmedEndTime
    protectedDebugTrackedPrimaryDir := mtfCurrentPrimaryDir
    protectedDebugHeldLevel := na
    protectedDebugHeldTime := na
    protectedDebugHeldValid := false
    protectedDebugHeldSource := "NONE"

if not mtfCurrentPrimaryExists
    mtfCurrentPrimaryProtectedMissingReason := "NO_CURRENT_PRIMARY"
else if not protectedDebugCurrentContextReady
    mtfCurrentPrimaryProtectedMissingReason := "PRIMARY_CONTEXT_INCOMPLETE"
else if mtfCurrentPrimaryDir == 1 and not protectedBullSwingPresent
    mtfCurrentPrimaryProtectedMissingReason := "NO_15M_SWING_LOW"
else if mtfCurrentPrimaryDir == -1 and not protectedBearSwingPresent
    mtfCurrentPrimaryProtectedMissingReason := "NO_15M_SWING_HIGH"
else if (mtfCurrentPrimaryDir == 1 and protectedBullSwingPresent and not bullProtectedTimeValid) or (mtfCurrentPrimaryDir == -1 and protectedBearSwingPresent and not bearProtectedTimeValid)
    mtfCurrentPrimaryProtectedMissingReason := "SWING_BEFORE_PRIMARY_LOCK"
else if (mtfCurrentPrimaryDir == 1 and protectedBullSwingPresent and bullProtectedTimeValid and not bullProtectedLevelCandidateValid) or (mtfCurrentPrimaryDir == -1 and protectedBearSwingPresent and bearProtectedTimeValid and not bearProtectedLevelCandidateValid)
    mtfCurrentPrimaryProtectedMissingReason := "SWING_OUTSIDE_PRIMARY_RANGE"
else
    mtfCurrentPrimaryProtectedMissingReason := "NONE"

if bullProtectedLevelCandidateValid
    mtfCurrentPrimaryProtectedLevel := confirmLatestSwingLowPrice
    mtfCurrentPrimaryProtectedTime := confirmLatestSwingLowTime
    mtfCurrentPrimaryProtectedValid := true
    mtfCurrentPrimaryProtectedSource := "15M_SWING_LOW_IN_1H_PRIMARY"
else if bearProtectedLevelCandidateValid
    mtfCurrentPrimaryProtectedLevel := confirmLatestSwingHighPrice
    mtfCurrentPrimaryProtectedTime := confirmLatestSwingHighTime
    mtfCurrentPrimaryProtectedValid := true
    mtfCurrentPrimaryProtectedSource := "15M_SWING_HIGH_IN_1H_PRIMARY"
else if protectedDebugCurrentContextReady
    mtfCurrentPrimaryProtectedSource := "NO_PROTECTED_SWING"

if mtfCurrentPrimaryProtectedValid
    protectedDebugHeldLevel := mtfCurrentPrimaryProtectedLevel
    protectedDebugHeldTime := mtfCurrentPrimaryProtectedTime
    protectedDebugHeldValid := true
    protectedDebugHeldSource := mtfCurrentPrimaryProtectedSource
else if protectedDebugCurrentContextReady and protectedDebugHeldValid and not na(protectedDebugHeldLevel) and not na(protectedDebugHeldTime)
    mtfCurrentPrimaryProtectedLevel := protectedDebugHeldLevel
    mtfCurrentPrimaryProtectedTime := protectedDebugHeldTime
    mtfCurrentPrimaryProtectedValid := true
    mtfCurrentPrimaryProtectedSource := protectedDebugHeldSource

float mtfCurrentPrimaryBreakLevel = na
string mtfCurrentPrimaryBreakMode = "NO_BREAK_LEVEL"
bool mtfCurrentPrimaryBreakByWick = false
bool mtfCurrentPrimaryBreakByClose = false
if mtfCurrentPrimaryExists and not na(mtfCurrentPrimaryRange) and mtfCurrentPrimaryRange > syminfo.mintick and mtfCurrentPrimaryDir != 0
    mtfCurrentPrimaryBreakLevel := mtfCurrentPrimaryDir == 1 ? mtfCurrentPrimaryHigh - mtfCurrentPrimaryRange * 0.79 : mtfCurrentPrimaryLow + mtfCurrentPrimaryRange * 0.79
    mtfCurrentPrimaryBreakMode := "CURRENT_PRIMARY_FIB79_15M_WICK"

bool lastActualCurrentBreakNow = false
int lastActualCurrentBreakTimeCandidate = na
float lastActualCurrentBreakPriceCandidate = na

if mtfCurrentPrimaryExists and mtfCurrentPrimaryActive and previousPrimaryAnchorExistsNow and not mtfRollbackToPreviousAnchor and not na(mtfCurrentPrimaryConfirmedEndTime)
    int confirmBarCount = array.size(confirmTimeArray)
    if confirmBarCount > 0
        for idx = 0 to confirmBarCount - 1
            int confirmBarTime = array.get(confirmTimeArray, idx)
            float confirmBarLow = array.get(confirmLowArray, idx)
            float confirmBarHigh = array.get(confirmHighArray, idx)
            bool confirmAfterCurrent = confirmBarTime >= mtfCurrentPrimaryConfirmedEndTime
            bool bullBreakNow = mtfCurrentPrimaryDir == 1 and confirmAfterCurrent and not na(mtfCurrentPrimaryBreakLevel) and confirmBarLow < mtfCurrentPrimaryBreakLevel
            bool bearBreakNow = mtfCurrentPrimaryDir == -1 and confirmAfterCurrent and not na(mtfCurrentPrimaryBreakLevel) and confirmBarHigh > mtfCurrentPrimaryBreakLevel
            if bullBreakNow or bearBreakNow
                lastActualCurrentBreakNow := true
                mtfCurrentPrimaryBreakByWick := true
                lastActualCurrentBreakTimeCandidate := confirmBarTime
                lastActualCurrentBreakPriceCandidate := mtfCurrentPrimaryBreakLevel

if lastActualCurrentBreakNow
    mtfCurrentPrimaryActive := false
    mtfCurrentPrimaryBroken := true
    mtfRollbackToPreviousAnchor := previousPrimaryAnchorExistsNow
    mtfLastPrimaryBreakTime := lastActualCurrentBreakTimeCandidate

    if not na(finalPrimaryBreakLine)
        line.delete(finalPrimaryBreakLine)
        finalPrimaryBreakLine := na
    if not na(finalLblPrimaryBreak)
        label.delete(finalLblPrimaryBreak)
        finalLblPrimaryBreak := na

    finalPrimaryBreakLine := line.new(mtfCurrentPrimaryStartTime, lastActualCurrentBreakPriceCandidate, lastActualCurrentBreakTimeCandidate, lastActualCurrentBreakPriceCandidate, xloc=xloc.bar_time, extend=extend.none, color=color.red, width=2)
    finalLblPrimaryBreak := label.new(lastActualCurrentBreakTimeCandidate, lastActualCurrentBreakPriceCandidate, roleConfirmProof + " ПОДТВ. СЛОМ", xloc=xloc.bar_time, style=mtfCurrentPrimaryDir == 1 ? label.style_label_down : label.style_label_up, color=color.new(color.red, VIS_TRANS_STATE_LABEL), textcolor=color.white)

bool previousAnchorVisualAllowed = previousPrimaryAnchorExistsNow
bool currentPrimaryVisualAllowed = mtfCurrentPrimaryExists
bool currentPrimaryIsBrokenVisual = mtfCurrentPrimaryExists and mtfCurrentPrimaryBroken
bool currentPrimaryIsActiveVisual = mtfCurrentPrimaryExists and mtfCurrentPrimaryActive and not mtfCurrentPrimaryBroken
bool activeOwnerIsCurrent = mtfCurrentPrimaryExists and mtfCurrentPrimaryActive and not mtfCurrentPrimaryBroken and not mtfRollbackToPreviousAnchor
bool activeOwnerIsPreviousAfterRollback = previousAnchorActiveValid and mtfRollbackToPreviousAnchor
bool activeOwnerIsPreviousFallback = previousOwnerFallbackAllowed and not activeOwnerIsCurrent
bool activeOwnerIsPreviousAnchor = activeOwnerIsPreviousAfterRollback or activeOwnerIsPreviousFallback
bool activeOwnerExistsFinal = activeOwnerIsCurrent or activeOwnerIsPreviousAnchor
string activeOwnerStateFinal = activeOwnerIsCurrent ? "CURRENT" : activeOwnerIsPreviousAfterRollback ? "PREVIOUS_AFTER_ROLLBACK" : activeOwnerIsPreviousAnchor ? "PREVIOUS" : "NONE"
string fibOwnerStateFinal = activeOwnerIsCurrent ? "CURRENT" : activeOwnerIsPreviousAnchor ? "PREVIOUS" : "NONE"
string currentLockStateFinal = currentPrimaryIsActiveVisual ? "LOCKED" : currentPrimaryIsBrokenVisual ? "BROKEN" : currentPrimaryVisualAllowed ? "INACTIVE" : "NONE"
string previousAnchorStateFinal = not previousAnchorExistsFinal ? "NONE" : previousAnchorBrokenByClose ? "BROKEN" : previousAnchorStaleByExpansion ? "STALE" : activeOwnerIsPreviousAnchor ? "ACTIVE" : "REFERENCE"
bool rearmWaitNewPoi = false
bool rearmWaitPrimary = false
bool rearmLockedCurrent = false
string rearmStateFinal = "REARM_NONE_OFF"
string rearmReasonFinal = "NO_REARM_NEEDED"
string breakStateFinal = mtfCurrentPrimaryBroken and not activeOwnerExistsFinal ? "BROKEN_PRIMARY_OWNER_NONE" : mtfCurrentPrimaryBroken and mtfRollbackToPreviousAnchor ? "BROKEN_PRIMARY_ROLLBACK_TO_POI" : mtfCurrentPrimaryBroken ? "BROKEN_PRIMARY" : "NO_BREAK"

if activeOwnerIsCurrent
    rearmStateFinal := "REARM_LOCKED_CURRENT"
    rearmReasonFinal := "1H_PRIMARY_OWNER_ACTIVE"
    rearmLockedCurrent := true
else if not activeOwnerExistsFinal and not previousAnchorActiveValid
    rearmStateFinal := "WAIT_NEW_POI"
    rearmReasonFinal := mtfCurrentPrimaryBroken ? "PRIMARY_BROKEN_POI_INVALID" : "NO_VALID_4H_POI"
    rearmWaitNewPoi := true
else if not activeOwnerExistsFinal and previousAnchorActiveValid
    rearmStateFinal := "WAIT_PRIMARY_IN_POI"
    rearmReasonFinal := "VALID_4H_POI_WAIT_1H_PRIMARY"
    rearmWaitPrimary := true
else if activeOwnerIsPreviousAnchor or activeOwnerIsPreviousAfterRollback
    rearmStateFinal := "WAIT_PRIMARY_IN_POI"
    rearmReasonFinal := mtfCurrentPrimaryBroken ? "PRIMARY_BROKEN_ROLLBACK_TO_POI" : "4H_POI_OWNER_WAIT_1H_PRIMARY"
    rearmWaitPrimary := true

string activeOwnerStateDisplayRu = f_ruOwnerState(activeOwnerStateFinal)
