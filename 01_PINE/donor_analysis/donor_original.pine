    finalTemp079Line := line.new(temp079LineStartTime, mtfCurrentPrimaryBreakLevel, time, mtfCurrentPrimaryBreakLevel, xloc=xloc.bar_time, extend=extend.right, color=temp079DebugColor, style=line.style_dotted, width=1)
    finalLblTemp079 := label.new(temp079LineStartTime, mtfCurrentPrimaryBreakLevel, "ВРЕМ. 0.79", xloc=xloc.bar_time, style=mtfCurrentPrimaryDir == 1 ? label.style_label_up : label.style_label_down, color=temp079LabelColor, textcolor=color.white)

if not na(finalFibLine0)
